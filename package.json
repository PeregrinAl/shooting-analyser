{
  "name": "shooting-analyser",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Локальный инструмент дисперсионного анализа серий стрелковой подготовки.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
