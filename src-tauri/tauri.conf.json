{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shooting-analyser",
  "version": "0.4.1",
  "identifier": "io.github.shooting-analyser",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "shooting-analyser",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Education",
    "targets": "all",
    "shortDescription": "Анализ серий стрелковой подготовки",
    "longDescription": "Локальный инструмент дисперсионного анализа серий стрелковой подготовки. Работает офлайн, без отправки данных.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "plugins": {}
}
